# Qurasearch server configuration — copy to .env for local dev.
# Secrets are never committed; this file documents the shape (docs/engineering.md §8).

PORT=8787
DATABASE_URL=postgresql://qurasearch:change-me@localhost:5432/qurasearch
# Generate >=32 random chars, e.g.: openssl rand -base64 48
JWT_SECRET=

# SMTP (phase 1 — verify/reset email, docs/sync-and-accounts.md §11)
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
